{
  "manifest_version": 3,
  "name": "Dynamic Auto-Fill",
  "version": "1.3",
  "description": "Securely store your information and auto-fill web forms with custom fields, cloud sync, and effortless backup controls.",
  "homepage_url": "https://github.com/Vimy16/auto-filler-extension",

  "icons": {
    "128": "icon.png"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "identity",
    "identity.email"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
